---
import type { WorkflowHealthSignal } from '../lib/workflow-health';

interface Props {
  signals: WorkflowHealthSignal[];
}

const { signals } = Astro.props as Props;

function badgeClass(state: WorkflowHealthSignal['state']) {
  if (state === 'good') return 'badge-good';
  if (state === 'warn') return 'badge-warn';
  return 'badge';
}
---
<section class="mb-10">
  <div class="mb-4">
    <p class="text-[11px] uppercase tracking-[0.24em] text-text-subtle mb-2">Workflow health</p>
    <h2 class="text-2xl font-bold tracking-tight">Signals from this stack surface</h2>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
    {signals.map((signal) => (
      <article class="rounded-[1.5rem] border border-line bg-bg-surface/60 p-5">
        <div class="flex items-center justify-between gap-3">
          <h3 class="text-base font-semibold">{signal.label}</h3>
          <span class:list={[badgeClass(signal.state)]}>
            {signal.state === 'good' ? 'Healthy' : signal.state === 'warn' ? 'Needs work' : 'Watch'}
          </span>
        </div>
        <p class="mt-3 text-sm text-text-muted leading-relaxed">{signal.detail}</p>
      </article>
    ))}
  </div>
</section>
