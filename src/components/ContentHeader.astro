---
import Badge from './Badge.astro';
import MetaGrid from './MetaGrid.astro';

interface Props {
  title: string;
  description: string;
  type: string;
  tags?: string[];
  meta?: { label: string; value: string | boolean | string[] | undefined | null }[];
}

const { title, description, type, tags = [], meta = [] } = Astro.props;
---
<header class="mb-8">
  <!-- Type & Tags -->
  <div class="flex flex-wrap items-center gap-2 mb-4">
    <Badge label={type} tone="accent" size="md" />
    {tags.slice(0, 6).map((tag) => <Badge label={tag} />)}
  </div>

  <!-- Title -->
  <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-[1.1] mb-4">
    {title}
  </h1>

  <!-- Description -->
  <p class="text-lg text-text-muted leading-relaxed max-w-2xl">
    {description}
  </p>

  <!-- Meta Grid -->
  {meta.length > 0 && <MetaGrid items={meta} />}
</header>
