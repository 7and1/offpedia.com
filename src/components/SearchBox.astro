---
interface Props {
  placeholder?: string;
  autofocus?: boolean;
}
const { placeholder = 'Search stacks, wiki, kits, guides...', autofocus = false } = Astro.props;
---
<div class="search-widget relative w-full max-w-2xl" data-search>
  <div class="relative">
    <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-text-subtle pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <input
      type="search"
      placeholder={placeholder}
      aria-label="Search Offpedia"
      class="w-full bg-bg-surface/80 border border-line rounded-full pl-12 pr-4 py-3.5 text-text placeholder:text-text-subtle focus:outline-none focus:border-accent/50 focus:ring-2 focus:ring-accent/10 transition-all"
      data-search-input
    />
    <kbd class="hidden sm:flex absolute right-4 top-1/2 -translate-y-1/2 items-center gap-0.5 px-2 py-0.5 rounded bg-bg-elevated border border-line text-xs text-text-subtle" data-search-kbd>
      <span class="text-[10px]">⌘</span>K
    </kbd>
  </div>
  <div class="search-results absolute top-full left-0 right-0 mt-2 bg-bg-surface border border-line rounded-2xl shadow-2xl shadow-black/40 overflow-hidden z-50 hidden" data-search-results>
    <div class="max-h-[400px] overflow-y-auto p-2 space-y-1" data-search-list></div>
    <div class="px-4 py-2 border-t border-line text-xs text-text-subtle flex items-center justify-between">
      <span data-search-count></span>
      <span>↑↓ Navigate · Enter Select · Esc Close</span>
    </div>
  </div>
</div>

<script>
  const widgets = document.querySelectorAll('[data-search]');

  widgets.forEach((widget) => {
    const input = widget.querySelector('[data-search-input]') as HTMLInputElement;
    const results = widget.querySelector('[data-search-results]') as HTMLElement;
    const list = widget.querySelector('[data-search-list]') as HTMLElement;
    const count = widget.querySelector('[data-search-count]') as HTMLElement;
    const kbd = widget.querySelector('[data-search-kbd]') as HTMLElement;
    let index: any[] = [];
    let fuse: any = null;

    async function loadIndex() {
      try {
        const res = await fetch('/search-index.json');
        index = await res.json();
        const { default: Fuse } = await import('https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.mjs');
        fuse = new Fuse(index, {
          keys: [
            { name: 'title', weight: 3 },
            { name: 'tags', weight: 2 },
            { name: 'description', weight: 1.5 },
            { name: 'body', weight: 0.5 },
          ],
          threshold: 0.3,
          includeScore: true,
        });
      } catch (e) {
        console.warn('Search index load failed', e);
      }
    }

    function render(items: any[]) {
      if (!items.length) {
        list.innerHTML = '<div class="px-4 py-6 text-center text-text-subtle text-sm">No results found</div>';
        count.textContent = '0 results';
        results.classList.remove('hidden');
        return;
      }
      count.textContent = `${items.length} result${items.length > 1 ? 's' : ''}`;
      list.innerHTML = items.slice(0, 10).map((item, i) => `
        <a href="${item.url}" class="flex items-start gap-3 px-3 py-2.5 rounded-xl hover:bg-bg-elevated transition-colors no-underline group" data-result-item="${i}">
          <span class="shrink-0 mt-0.5 px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider bg-bg-elevated text-text-subtle border border-line">${item.collection}</span>
          <div class="min-w-0">
            <div class="text-sm font-medium text-text group-hover:text-accent transition-colors truncate">${item.title}</div>
            <div class="text-xs text-text-muted mt-0.5 line-clamp-1">${item.description}</div>
          </div>
        </a>
      `).join('');
      results.classList.remove('hidden');
    }

    function hide() {
      results.classList.add('hidden');
    }

    input?.addEventListener('input', () => {
      const q = input.value.trim();
      if (!q) { hide(); return; }
      if (fuse) {
        const matches = fuse.search(q).map((r: any) => r.item);
        render(matches);
      } else {
        const terms = q.toLowerCase().split(/\s+/);
        const matches = index.filter((item) => {
          const haystack = `${item.title} ${item.description} ${item.tags?.join(' ')} ${item.body}`.toLowerCase();
          return terms.every((term) => haystack.includes(term));
        });
        render(matches);
      }
    });

    input?.addEventListener('focus', () => {
      if (input.value.trim()) input.dispatchEvent(new Event('input'));
    });

    document.addEventListener('click', (e) => {
      if (!widget.contains(e.target as Node)) hide();
    });

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        input?.focus();
      }
      if (e.key === 'Escape') {
        hide();
        input?.blur();
      }
    });

    loadIndex();
  });
</script>
