---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentHeader from '../../components/ContentHeader.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { articleFaqSchema } from '../../lib/pseo';

export async function getStaticPaths() {
  const entries = await getCollection('guides');
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const relatedLinks = [
  ...(entry.data.relatedStack ? [{ label: entry.data.relatedStack, href: `/stacks/${entry.data.relatedStack}`, type: 'Stack' }] : []),
  ...entry.data.relatedKits.map((k: string) => ({ label: k, href: `/kits/${k}`, type: 'Kit' })),
  ...entry.data.relatedWiki.map((w: string) => ({ label: w, href: `/wiki/${w}`, type: 'Wiki' })),
];
const siteOrigin = Astro.site ?? Astro.url.origin;
const structuredData = articleFaqSchema({
  title: entry.data.title,
  description: entry.data.description,
  url: Astro.url.href,
  faq: entry.data.faq,
  breadcrumbs: [
    { name: 'Home', url: new URL('/', siteOrigin).href },
    { name: 'Guides', url: new URL('/guides/', siteOrigin).href },
    { name: entry.data.title, url: Astro.url.href },
  ],
});
---
<BaseLayout title={entry.data.title} description={entry.data.description} type="article" structuredData={structuredData}>
  <article class="container-content py-10 sm:py-14">
    <Breadcrumb items={[{ label: 'Guides', href: '/guides' }, { label: entry.data.title }]} />

    <ContentHeader
      title={entry.data.title}
      description={entry.data.description}
      type="Guide"
      tags={entry.data.tags}
      meta={[
        { label: 'Difficulty', value: entry.data.difficulty },
        { label: 'Time required', value: entry.data.timeRequired },
        { label: 'Related stack', value: entry.data.relatedStack },
        { label: 'Related kits', value: entry.data.relatedKits },
      ]}
    />

    <section class="rounded-2xl border border-accent/25 bg-accent/10 p-5 sm:p-6 mb-10">
      <p class="text-[11px] uppercase tracking-[0.24em] text-accent mb-3">Quick answer</p>
      <p class="text-xl sm:text-2xl font-semibold leading-snug text-text">{entry.data.quickAnswer}</p>
    </section>

    <!-- Content -->
    <div class="prose">
      <Content />
    </div>

    {entry.data.faq.length > 0 && (
      <section class="mt-10">
        <h2 class="text-2xl font-bold mb-4">FAQ</h2>
        <div class="space-y-4">
          {entry.data.faq.map((item: { question: string; answer: string }) => (
            <details class="card-base">
              <summary class="cursor-pointer font-semibold text-text">{item.question}</summary>
              <p class="mt-3 text-sm text-text-muted">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <!-- Related -->
    <RelatedLinks title="Related content" links={relatedLinks} />
  </article>

  <TableOfContents headings={headings} />
</BaseLayout>
