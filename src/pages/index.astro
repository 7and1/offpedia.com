---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import SearchBox from '../components/SearchBox.astro';
import DecisionCard from '../components/DecisionCard.astro';
import StackGeneratorIsland from '../components/StackGeneratorIsland';
import { buildStackGeneratorCatalog } from '../lib/stack-generator-data';
import { workflowRecommendations } from '../lib/workflow-advisor';

const [stackEntries, kitEntries, guideEntries, compareEntries] = await Promise.all([
  getCollection('stacks'),
  getCollection('kits'),
  getCollection('guides'),
  getCollection('compare'),
]);
const stacks = stackEntries.slice(0, 3);
const kits = kitEntries.slice(0, 3);
const guides = guideEntries.slice(0, 3);
const generatorCatalog = buildStackGeneratorCatalog(stackEntries, kitEntries, guideEntries);
const compare = compareEntries
  .filter((entry) => ['obsidian-vs-notion', 'obsidian-vs-logseq', 'quartz-vs-docusaurus'].includes(entry.slug))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---
<BaseLayout
  title="Offpedia"
  description="Choose a durable knowledge workflow before you rebuild it again. Offpedia helps writers, researchers, and personal wiki builders choose portable tool stacks, starter kits, and setup paths."
>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(110,231,183,0.14),transparent_26rem),radial-gradient(circle_at_top_right,rgba(147,197,253,0.12),transparent_28rem)] pointer-events-none"></div>
    <div class="container-wide relative py-16 sm:py-20 lg:py-24">
      <div class="grid grid-cols-1 xl:grid-cols-[0.9fr_1.1fr] gap-10 items-start">
        <div class="max-w-2xl">
          <p class="text-[11px] uppercase tracking-[0.28em] text-text-subtle mb-5">Workflow advisor for durable knowledge systems</p>
          <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold tracking-tight leading-[0.94]">
            Choose a durable knowledge workflow
            <span class="text-gradient block mt-2">before you rebuild it again.</span>
          </h1>

          <p class="text-lg sm:text-xl text-text-muted max-w-2xl mt-6 leading-relaxed">
            Offpedia helps writers, researchers, and personal wiki builders choose portable tool stacks, download starter kits, and follow setup paths that avoid lock-in.
          </p>

          <div class="flex flex-wrap gap-3 mt-8">
            <a class="btn-primary text-base px-7 py-3" href="/finder">Run the stack generator</a>
            <a class="btn-secondary text-base px-7 py-3" href="/stacks">Browse proven stacks</a>
          </div>

          <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-3">
            <div class="rounded-3xl border border-line bg-bg-surface/50 p-4">
              <p class="text-xs uppercase tracking-[0.18em] text-text-subtle mb-2">Today</p>
              <p class="text-sm text-text-muted">Run the generator and get one recommendation with a next action.</p>
            </div>
            <div class="rounded-3xl border border-line bg-bg-surface/50 p-4">
              <p class="text-xs uppercase tracking-[0.18em] text-text-subtle mb-2">Trust</p>
              <p class="text-sm text-text-muted">Recommendations show criteria, tradeoffs, sources, limitations, and update dates.</p>
            </div>
            <div class="rounded-3xl border border-line bg-bg-surface/50 p-4">
              <p class="text-xs uppercase tracking-[0.18em] text-text-subtle mb-2">Escape hatch</p>
              <p class="text-sm text-text-muted">If the recommendation is wrong for you, the closest alternative is right beside it.</p>
            </div>
          </div>
        </div>

        <StackGeneratorIsland
          client:load
          catalog={generatorCatalog}
          embedded={true}
          layout="stacked"
          title="Run the Stack Generator"
          intro="Start from the job, the archive constraints, and the collaboration pressure. Offpedia returns one stack plus the next action that makes it real."
        />
      </div>
    </div>
  </section>

  <section class="container-wide py-14 sm:py-20">
    <div class="flex items-end justify-between gap-6 mb-8">
      <div>
        <h2 class="section-title">What you get today</h2>
        <p class="section-subtitle">Offpedia is most useful when it ends in a concrete action, not just a content browse.</p>
      </div>
      <a href="/finder" class="hidden sm:flex btn-ghost text-sm">Open generator →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <DecisionCard
        eyebrow="Recommendation"
        title="One primary path"
        description="The generator returns one workflow stack with a reason, a warning, and the nearest alternative."
        chooseIf={['You want a recommendation without searching the whole site.', 'You need a concrete place to start today.']}
        action={{ label: 'Run Stack Generator', href: '/finder', kind: 'Generator' }}
      />
      <DecisionCard
        eyebrow="Kit"
        title="A starter structure"
        description="Download a vault kit or open a stack page that already explains the folder model and next move."
        chooseIf={['You want templates and folders, not abstract tool advice.', 'You want to start inside Obsidian today.']}
        action={{ label: 'Browse starter kits', href: '/kits', kind: 'Kits' }}
      />
      <DecisionCard
        eyebrow="Guide"
        title="A setup path"
        description="Follow a practical guide for sync, publishing, or frontmatter design once the workflow choice is made."
        chooseIf={['You already know your stack and need the next implementation step.', 'You want a predictable setup path.']}
        action={{ label: 'Read setup guides', href: '/guides', kind: 'Guides' }}
      />
    </div>
  </section>

  <section class="container-wide py-14 sm:py-20 border-t border-line">
    <div class="mb-8">
      <h2 class="section-title">Choose your entry path</h2>
      <p class="section-subtitle">Start from the job you are trying to do, not from the full reference catalog.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
      {workflowRecommendations.map((profile) => (
        <DecisionCard
          eyebrow={profile.shortLabel}
          title={profile.recommendedPath.label}
          description={profile.summary}
          chooseIf={profile.criteria.slice(0, 3)}
          avoidIf={[profile.warning]}
          action={profile.todayAction}
          alternative={profile.alternative}
        />
      ))}
    </div>
  </section>

  <section class="container-wide py-14 sm:py-20 border-t border-line">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <article class="rounded-[2rem] border border-line bg-bg-surface/60 p-6 sm:p-8">
        <p class="text-[11px] uppercase tracking-[0.24em] text-text-subtle mb-3">How recommendations work</p>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">Criteria before ideology</h2>
        <p class="mt-3 text-text-muted max-w-2xl">
          Offpedia does not recommend a workflow just because it is local-first. The recommendation has to survive real tradeoffs.
        </p>
        <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
          {['Portability', 'Offline access', 'Git support', 'Collaboration fit', 'Publishing path', 'Migration risk'].map((item) => (
            <div class="rounded-3xl border border-line bg-bg/40 px-4 py-4 text-sm text-text-muted">{item}</div>
          ))}
        </div>
      </article>

      <article class="rounded-[2rem] border border-line bg-bg-surface/60 p-6 sm:p-8">
        <p class="text-[11px] uppercase tracking-[0.24em] text-text-subtle mb-3">When not to choose local-first</p>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">Cloud-first is sometimes the right answer</h2>
        <ul class="mt-6 space-y-3 text-text-muted">
          <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 rounded-full bg-amber-300 shrink-0"></span><span>Use a compare-first path when the team needs realtime collaborative editing.</span></li>
          <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 rounded-full bg-amber-300 shrink-0"></span><span>Prefer docs frameworks or shared workspaces when the workflow depends on versioned team docs or lightweight databases.</span></li>
          <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 rounded-full bg-amber-300 shrink-0"></span><span>A low Git tolerance is a real constraint, not a moral failure. The recommendation should respect it.</span></li>
        </ul>
      </article>
    </div>
  </section>

  <section class="container-wide py-14 sm:py-20 border-t border-line">
    <div class="flex items-end justify-between mb-8">
      <div>
        <h2 class="section-title">Popular alternatives</h2>
        <p class="section-subtitle">The fallback path should be visible before you commit to a stack.</p>
      </div>
      <a href="/compare" class="hidden sm:flex btn-ghost text-sm">View all comparisons →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {compare.map((entry) => (
        <Card
          href={`/compare/${entry.slug}`}
          title={entry.data.title}
          description={entry.data.quickAnswer}
          badges={entry.data.tools}
        />
      ))}
    </div>
  </section>

  <section class="container-wide py-14 sm:py-20 border-t border-line">
    <div class="flex items-end justify-between mb-8">
      <div>
        <h2 class="section-title">Proven stacks</h2>
        <p class="section-subtitle">Flagship stacks lead with verdicts, ideal users, avoid-if warnings, and the matching next step.</p>
      </div>
      <a href="/stacks" class="hidden sm:flex btn-ghost text-sm">View all stacks →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {stacks.map((entry) => (
        <Card
          href={`/stacks/${entry.slug}`}
          title={entry.data.title}
          description={entry.data.quickVerdict}
          badges={[entry.data.goal, entry.data.difficulty, entry.data.publishReady ? 'Publish-ready' : 'Workflow'] }
        />
      ))}
    </div>
  </section>

  <section class="container-wide py-14 sm:py-20 border-t border-line">
    <div class="grid grid-cols-1 xl:grid-cols-[1fr_0.8fr] gap-8 items-start">
      <div>
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 class="section-title">Starter kits</h2>
            <p class="section-subtitle">Product-like previews beat decorative art. See the folder tree and included files before you download.</p>
          </div>
          <a href="/kits" class="hidden sm:flex btn-ghost text-sm">View all kits →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
          {kits.map((entry) => (
            <Card
              href={`/kits/${entry.slug}`}
              title={entry.data.title}
              description={entry.data.outcome}
              badges={['Template', entry.data.stack, ...entry.data.plugins.slice(0, 1)]}
            />
          ))}
        </div>
      </div>

      <div class="rounded-[2rem] border border-line bg-bg-surface/60 p-6 sm:p-8">
        <p class="text-[11px] uppercase tracking-[0.24em] text-text-subtle mb-3">Reference material</p>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">Support the decision with the reference layer</h2>
        <p class="mt-3 text-text-muted">
          Wiki entries still matter, but they now support a workflow decision instead of replacing one.
        </p>
        <div class="mt-6">
          <SearchBox placeholder="Search stacks, compare pages, kits, guides... (⌘K)" />
        </div>
        <div class="mt-6 grid grid-cols-1 gap-3">
          {guides.map((entry) => (
            <Card
              href={`/guides/${entry.slug}`}
              title={entry.data.title}
              description={entry.data.description}
              badges={[entry.data.difficulty, entry.data.timeRequired]}
            />
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
