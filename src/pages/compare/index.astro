---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCompareEligibleTools, getComparePairs } from '../../lib/pseo';

const [wikiEntries, compareEntries] = await Promise.all([
  getCollection('wiki'),
  getCollection('compare'),
]);
const pairs = getComparePairs(getCompareEligibleTools(wikiEntries));
const manualBySlug = new Map(compareEntries.map((entry) => [entry.slug, entry]));
const generatedCards = pairs.map((pair) => {
  const manual = manualBySlug.get(pair.slug);
  return {
    slug: pair.slug,
    title: manual?.data.title ?? `${pair.tools[0].data.title} vs ${pair.tools[1].data.title}`,
    description:
      manual?.data.description ??
      `Compare ${pair.tools[0].data.title} and ${pair.tools[1].data.title} by fit, portability, pricing, Git support, and workflow role.`,
    badges: pair.tools.map((tool) => tool.data.title),
  };
});
const generated = new Set(generatedCards.map((card) => card.slug));
const manualOnlyCards = compareEntries
  .filter((entry) => !generated.has(entry.slug))
  .map((entry) => ({
    slug: entry.slug,
    title: entry.data.title,
    description: entry.data.description,
    badges: entry.data.tools,
  }));
const cards = [...generatedCards, ...manualOnlyCards].sort((a, b) => a.title.localeCompare(b.title));
---
<BaseLayout title="Compare" description="Compare local-first tools and publishing workflows with structured decision pages.">
  <section class="container-wide py-12 sm:py-16">
    <Breadcrumb items={[{ label: 'Compare' }]} />

    <div class="max-w-3xl mb-10">
      <h1 class="section-title text-3xl sm:text-4xl">Compare</h1>
      <p class="section-subtitle">
        对比页帮助用户在相近工具之间做选择。手写页面优先展示编辑判断，其余工具组合用结构化模板补齐决策信息。
      </p>
      <p class="mt-3 text-sm text-text-muted">
        当前矩阵包含 {pairs.length} 个自动工具组合，并保留 {compareEntries.length} 个编辑对比入口。
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {cards.map((entry) => (
        <Card
          href={`/compare/${entry.slug}`}
          title={entry.title}
          description={entry.description}
          badges={entry.badges}
        />
      ))}
    </div>
  </section>
</BaseLayout>
