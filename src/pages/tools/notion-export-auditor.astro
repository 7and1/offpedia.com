---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { breadcrumbListSchema } from '../../lib/pseo';

const siteOrigin = Astro.site ?? Astro.url.origin;
const faq = [
  {
    question: 'Does Offpedia upload my Notion export?',
    answer: 'No. The auditor is a local CLI wrapper around repository scripts. It reads a directory on your machine and writes reports to the output path you choose.',
  },
  {
    question: 'Can I publish the generated report directly?',
    answer: 'Do not publish private reports without review. Reports can include local paths, filenames, page titles, and attachment names from your export.',
  },
  {
    question: 'What should I run after Obsidian Importer?',
    answer: 'Use the pair audit command with the raw export as before and the imported vault as after, then review fixed, remaining, and newly introduced findings.',
  },
];
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: 'Notion Export Auditor',
      description: 'A local audit workflow for finding cleanup risks in Notion exports before Obsidian migration or publishing.',
      url: Astro.url.href,
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'macOS, Linux, Windows',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
    },
    {
      '@type': 'SoftwareApplication',
      name: 'Notion Export Auditor',
      description: 'CLI scripts for auditing Notion export folders and before-after Obsidian Importer results.',
      url: Astro.url.href,
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Node.js',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faq.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    },
    breadcrumbListSchema([
      { name: 'Home', url: new URL('/', siteOrigin).href },
      { name: 'Tools', url: new URL('/tools/', siteOrigin).href },
      { name: 'Notion Export Auditor', url: Astro.url.href },
    ]),
  ],
};
const relatedLinks = [
  { label: 'Notion to Obsidian cleanup checklist', href: '/guides/notion-to-obsidian-cleanup-checklist', type: 'Guide' },
  { label: 'Obsidian Importer before-after audit', href: '/guides/obsidian-importer-before-after-audit', type: 'Guide' },
  { label: 'Notion export sample audit report', href: '/guides/notion-export-sample-audit-report', type: 'Guide' },
  { label: 'Notion export', href: '/wiki/concepts/notion-export', type: 'Wiki' },
];
---
<BaseLayout
  title="Notion Export Auditor"
  description="Run a local CLI audit on a Notion export before cleaning it up for Obsidian, Bases, Quartz, or public publishing."
  type="article"
  structuredData={structuredData}
>
  <article class="container-content py-10 sm:py-14">
    <Breadcrumb items={[{ label: 'Tools', href: '/tools' }, { label: 'Notion Export Auditor' }]} />

    <header class="mb-10">
      <p class="text-[11px] uppercase tracking-[0.28em] text-text-subtle mb-4">Local CLI tool</p>
      <h1 class="text-3xl sm:text-5xl font-bold tracking-tight">Notion Export Auditor</h1>
      <p class="mt-5 text-lg text-text-muted max-w-3xl">
        Audit a Notion export folder before you clean it up for Obsidian, Obsidian Bases,
        Quartz, or public publishing. This is a local command-line workflow, not an upload tool.
      </p>
    </header>

    <section class="rounded-2xl border border-accent/25 bg-accent/10 p-5 sm:p-6 mb-10">
      <p class="text-[11px] uppercase tracking-[0.24em] text-accent mb-3">Privacy boundary</p>
      <p class="text-xl sm:text-2xl font-semibold leading-snug text-text">
        The auditor reads local folders and writes local reports. Do not upload private exports or publish raw reports without removing private paths, filenames, and page titles.
      </p>
    </section>

    <div class="prose">
      <h2>What it checks</h2>
      <p>
        The auditor is built for migration cleanup work. It flags common failure modes such as
        CSV database exports, missing local file references, Notion web URLs that survived import,
        duplicate page titles, HTML leftovers, large attachments, private-looking path names,
        and incomplete publishing metadata.
      </p>

      <h2>Run a single export audit</h2>
      <p>Run this from the Astro project directory after dependencies already exist:</p>
      <pre><code>npm run audit:notion -- &lt;notion-export-dir&gt; --out /tmp/notion-obsidian-audit</code></pre>
      <p>
        Use this before importing when you need an inventory of cleanup risks in the raw export.
        The output directory can contain machine-readable findings and human-readable summaries.
      </p>

      <h2>Compare before and after Obsidian Importer</h2>
      <p>
        Use the pair audit after you have both the raw Notion export and the imported Obsidian vault:
      </p>
      <pre><code>npm run audit:notion:pair -- --before &lt;raw-export-dir&gt; --after &lt;imported-vault-dir&gt; --sample-id SAMPLE-001 --out /tmp/offpedia-samples</code></pre>
      <p>
        This report is useful for seeing which risks the importer resolved, which risks remain,
        and which cleanup issues appeared after conversion.
      </p>

      <h2>What not to do</h2>
      <ul>
        <li>Do not paste private reports into public issues, docs, or examples without review.</li>
        <li>Do not treat a clean score as a full privacy audit; filenames and content still need human review.</li>
        <li>Do not assume database exports become clean Bases without mapping properties and views.</li>
      </ul>

      <h2>Best next step</h2>
      <p>
        Start with the cleanup checklist, then run the before-after audit once Obsidian Importer
        has produced a vault you can inspect locally.
      </p>
    </div>

    <section class="mt-10">
      <h2 class="text-2xl font-bold mb-4">FAQ</h2>
      <div class="space-y-4">
        {faq.map((item) => (
          <details class="card-base">
            <summary class="cursor-pointer font-semibold text-text">{item.question}</summary>
            <p class="mt-3 text-sm text-text-muted">{item.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <RelatedLinks title="Related cleanup paths" links={relatedLinks} />
  </article>
</BaseLayout>
