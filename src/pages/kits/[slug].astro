---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentHeader from '../../components/ContentHeader.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import KitPreview from '../../components/KitPreview.astro';

export async function getStaticPaths() {
  const entries = await getCollection('kits');
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const relatedLinks = [
  { label: entry.data.stack, href: `/stacks/${entry.data.stack}`, type: 'Stack' },
  ...entry.data.relatedGuides.map((g: string) => ({ label: g, href: `/guides/${g}`, type: 'Guide' })),
];
---
<BaseLayout title={entry.data.title} description={entry.data.description} type="article">
  <article class="container-content py-10 sm:py-14">
    <Breadcrumb items={[{ label: 'Kits', href: '/kits' }, { label: entry.data.title }]} />

    <ContentHeader
      title={entry.data.title}
      description={entry.data.description}
      type="Kit"
      tags={entry.data.tags}
      meta={[
        { label: 'Stack', value: entry.data.stack },
        { label: 'Last updated', value: entry.data.updatedAt.toISOString().slice(0, 10) },
        { label: 'Obsidian version', value: entry.data.obsidianVersion },
        { label: 'Plugins', value: entry.data.plugins },
        { label: 'Folders', value: entry.data.folders },
      ]}
    />

    <div class="flex flex-wrap gap-3 mb-8 p-6 bg-bg-surface/60 border border-line rounded-2xl">
      <div class="flex-1 min-w-0">
        <h3 class="text-lg font-semibold mb-1">Get this Kit</h3>
        <p class="text-sm text-text-muted">{entry.data.outcome}</p>
      </div>
      <div class="flex flex-wrap gap-3 items-center">
        {entry.data.templateRepo && (
          <a class="btn-primary" href={entry.data.templateRepo} target="_blank" rel="noopener">
            Use Template
          </a>
        )}
        {entry.data.downloadUrl && (
          <a class="btn-secondary" href={entry.data.downloadUrl} download>
            Download ZIP
          </a>
        )}
      </div>
    </div>

    <div class="mb-10">
      <KitPreview
        title={entry.data.title}
        folders={entry.data.folders}
        includedFiles={entry.data.includedFiles}
        notes={entry.data.previewNotes}
      />
    </div>

    <section class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-10">
      <article class="rounded-[2rem] border border-line bg-bg-surface/60 p-6 sm:p-8">
        <p class="text-[11px] uppercase tracking-[0.24em] text-text-subtle mb-3">Best next step</p>
        <h2 class="text-2xl font-bold tracking-tight">{entry.data.bestNextStep.label}</h2>
        {entry.data.bestNextStep.reason && <p class="mt-3 text-text-muted">{entry.data.bestNextStep.reason}</p>}
        <a class="btn-primary mt-6" href={entry.data.bestNextStep.href}>Open next step</a>
      </article>

      <article class="rounded-[2rem] border border-line bg-bg-surface/60 p-6 sm:p-8">
        <p class="text-[11px] uppercase tracking-[0.24em] text-text-subtle mb-3">Included files</p>
        <h2 class="text-2xl font-bold tracking-tight">What ships in the kit</h2>
        <ul class="mt-5 space-y-3 text-text-muted">
          {entry.data.includedFiles.map((file: string) => (
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 rounded-full bg-accent shrink-0"></span>
              <span>{file}</span>
            </li>
          ))}
        </ul>
      </article>
    </section>

    <div class="prose">
      <Content />
    </div>

    <RelatedLinks title="Related content" links={relatedLinks} />
  </article>

  <TableOfContents headings={headings} />
</BaseLayout>
